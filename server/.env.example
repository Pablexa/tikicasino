# TikiCasino Server Environment Variables
# Copy this file to .env and fill in your values

# App
PORT=3001
NODE_ENV=development
APP_URL=http://localhost:5173

# Security
JWT_SECRET=change-this-to-a-long-random-secret-in-production
COOKIE_SECRET=change-this-cookie-secret-too

# Database
# For local dev, SQLite is used automatically when DATABASE_URL is not set
# For production on Render, set DATABASE_URL to your PostgreSQL URL
# DATABASE_URL=postgresql://user:password@host:5432/tikicasino

# Email (optional - development mode works without this)
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.brevo.com
# SMTP_PORT=587
# SMTP_USER=your-brevo-email
# SMTP_PASS=your-brevo-api-key
# FROM_EMAIL=noreply@tikicasino.app
# FROM_NAME=TikiCasino
